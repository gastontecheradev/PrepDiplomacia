@{
    ViewData["Title"] = "Pago cancelado";
}

<section class="pd-page-hero">
    <div class="pd-wrap">
        <div class="pd-eyebrow pd-eyebrow--inverse"><span class="pd-eyebrow__line"></span>Pago cancelado</div>
        <h1 class="pd-h1 pd-h1--inverse">No completaste el pago</h1>
    </div>
</section>

<section class="pd-section">
    <div class="pd-wrap" style="max-width: 720px;">
        <div class="pd-alert pd-alert--info">
            <h3>Tu inscripción sigue guardada</h3>
            <p>Podés retomar el pago cuando quieras. Si tenés dudas o querés cambiar de plan, escribinos a <a href="mailto:prepdiplomaciauy@gmail.com">prepdiplomaciauy@gmail.com</a>.</p>
        </div>
        <p>
            <a class="pd-btn pd-btn--blue" asp-controller="Inscripcion" asp-action="Index">Volver a la inscripción</a>
        </p>
    </div>
</section>
