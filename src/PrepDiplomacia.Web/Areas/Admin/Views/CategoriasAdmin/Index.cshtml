@model List<CategoriaBlog>
@{ ViewData["Title"] = "Categorías y tags"; }

<header class="pd-admin__head">
    <div>
        <h1>Categorías y etiquetas</h1>
    </div>
</header>

<div class="pd-grid pd-grid--2">
    <div class="pd-card">
        <h3>Categorías</h3>
        <form asp-area="Admin" asp-controller="CategoriasAdmin" asp-action="Crear" method="post" class="pd-form pd-form--inline">
            @Html.AntiForgeryToken()
            <input name="Nombre" placeholder="Nueva categoría" required />
            <input name="Color" placeholder="#0C3F67" maxlength="7" />
            <button type="submit" class="pd-btn pd-btn--blue pd-btn--sm">Agregar</button>
        </form>

        @if (Model.Any())
        {
            <table class="pd-table pd-table--mini" style="margin-top: 16px;">
                <thead><tr><th>Nombre</th><th>Slug</th><th>Color</th><th></th></tr></thead>
                <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Nombre</td>
                        <td><small>@c.Slug</small></td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.Color))
                            {
                                <span style="display:inline-block; width:18px; height:18px; vertical-align: middle; background:@c.Color; border:1px solid #ccc;"></span> @c.Color
                            }
                        </td>
                        <td>
                            <form asp-area="Admin" asp-controller="CategoriasAdmin" asp-action="Eliminar" asp-route-id="@c.Id" method="post" style="display:inline" onsubmit="return confirm('¿Eliminar categoría?');">
                                @Html.AntiForgeryToken()
                                <button class="pd-link pd-link--danger" type="submit">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    <div class="pd-card">
        <h3>Tags</h3>
        <form asp-area="Admin" asp-controller="CategoriasAdmin" asp-action="CrearTag" method="post" class="pd-form pd-form--inline">
            @Html.AntiForgeryToken()
            <input name="nombre" placeholder="Nueva etiqueta" required />
            <button type="submit" class="pd-btn pd-btn--blue pd-btn--sm">Agregar</button>
        </form>
        <p class="pd-muted" style="margin-top: 12px;">Los tags existentes se asignan a cada post desde la pantalla de edición.</p>
    </div>
</div>
