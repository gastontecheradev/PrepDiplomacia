@model RecuperarPasswordViewModel
@{ ViewData["Title"] = "Recuperar contraseña"; }

<section class="pd-section">
    <div class="pd-wrap" style="max-width: 460px;">
        <div class="pd-section__head pd-section__head--center">
            <div class="pd-eyebrow"><span class="pd-eyebrow__line"></span>Recuperar acceso</div>
            <h1 class="pd-h2">Recuperar contraseña</h1>
            <p class="pd-lead">Te enviaremos un enlace al correo registrado.</p>
        </div>

        <form asp-controller="Cuenta" asp-action="RecuperarPassword" method="post" class="pd-form">
            @Html.AntiForgeryToken()
            <div class="pd-form__field">
                <label asp-for="Email"></label>
                <input asp-for="Email" type="email" />
                <span asp-validation-for="Email"></span>
            </div>
            <button type="submit" class="pd-btn pd-btn--blue">Enviar enlace</button>
        </form>
    </div>
</section>
