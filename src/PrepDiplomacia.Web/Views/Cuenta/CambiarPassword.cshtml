@model CambiarPasswordViewModel
@{ ViewData["Title"] = "Cambiar contraseña"; }

<section class="pd-section">
    <div class="pd-wrap" style="max-width: 460px;">
        <div class="pd-section__head pd-section__head--center">
            <div class="pd-eyebrow"><span class="pd-eyebrow__line"></span>Mi cuenta</div>
            <h1 class="pd-h2">Cambiar contraseña</h1>
        </div>

        <form asp-controller="Cuenta" asp-action="CambiarPassword" method="post" class="pd-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="pd-form__error"></div>

            <div class="pd-form__field">
                <label asp-for="PasswordActual"></label>
                <input asp-for="PasswordActual" type="password" />
                <span asp-validation-for="PasswordActual"></span>
            </div>
            <div class="pd-form__field">
                <label asp-for="PasswordNueva"></label>
                <input asp-for="PasswordNueva" type="password" />
                <span asp-validation-for="PasswordNueva"></span>
            </div>
            <div class="pd-form__field">
                <label asp-for="ConfirmarPasswordNueva"></label>
                <input asp-for="ConfirmarPasswordNueva" type="password" />
                <span asp-validation-for="ConfirmarPasswordNueva"></span>
            </div>

            <button type="submit" class="pd-btn pd-btn--blue">Guardar</button>
        </form>
    </div>
</section>
