@model ResetPasswordViewModel
@{ ViewData["Title"] = "Restablecer contraseña"; }

<section class="pd-section">
    <div class="pd-wrap" style="max-width: 460px;">
        <div class="pd-section__head pd-section__head--center">
            <div class="pd-eyebrow"><span class="pd-eyebrow__line"></span>Nueva contraseña</div>
            <h1 class="pd-h2">Restablecer contraseña</h1>
        </div>

        <form asp-controller="Cuenta" asp-action="ResetPassword" method="post" class="pd-form">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="Token" />
            <div asp-validation-summary="ModelOnly" class="pd-form__error"></div>

            <div class="pd-form__field">
                <label asp-for="Password"></label>
                <input asp-for="Password" type="password" />
                <span asp-validation-for="Password"></span>
            </div>
            <div class="pd-form__field">
                <label asp-for="ConfirmarPassword"></label>
                <input asp-for="ConfirmarPassword" type="password" />
                <span asp-validation-for="ConfirmarPassword"></span>
            </div>

            <button type="submit" class="pd-btn pd-btn--blue">Guardar contraseña</button>
        </form>
    </div>
</section>
