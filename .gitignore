# ============================================================
#  .gitignore — PrepDiplomacia (.NET 8)
#  Bloquea TODO lo que sean secretos, build outputs y bases de datos.
# ============================================================

# === Build / Bin / Obj ===
**/bin/
**/obj/
**/out/
**/[Dd]ebug/
**/[Rr]elease/
**/x64/
**/x86/
**/[Ww][Ii][Nn]32/
**/[Aa][Rr][Mm]/
**/[Aa][Rr][Mm]64/
**/bld/
**/[Ll]og/
**/[Ll]ogs/

# === Visual Studio / Rider / VS Code ===
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.DS_Store
Thumbs.db
*.swp
*~

# === ASP.NET artefactos ===
PublishProfiles/
*.pubxml
*.pubxml.user
*.publishsettings
publish/

# === Tests / coverage ===
TestResults/
coverage*.json
coverage*.xml
*.coverage
*.coveragexml

# === Bases de datos locales (SQLite) ===
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
src/PrepDiplomacia.Web/App_Data/

# === Secretos / variables de entorno ===
# NUNCA subir secretos a git
appsettings.Production.json
appsettings.Local.json
appsettings.Development.json
*.env
.env
.env.*
secrets.json
**/secrets.json

# User Secrets de .NET (los maneja dotnet user-secrets, no versionar)
**/UserSecrets/

# === Uploads de usuarios ===
# El admin sube imágenes en runtime. No deben subirse al repo.
src/PrepDiplomacia.Web/wwwroot/uploads/blog/*
src/PrepDiplomacia.Web/wwwroot/uploads/contenido/*
!src/PrepDiplomacia.Web/wwwroot/uploads/blog/.gitkeep
!src/PrepDiplomacia.Web/wwwroot/uploads/contenido/.gitkeep

# === NuGet ===
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# === Node (por si en el futuro se agrega tooling) ===
node_modules/
npm-debug.log
yarn-error.log

# === SO ===
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# === Certificados / claves ===
*.pfx
*.p12
*.key
*.pem
*.cer
*.crt

# === Logs de aplicación ===
*.log
src/PrepDiplomacia.Web/Logs/

# === Backups ===
*.bak
*.backup
*.old
*.orig
